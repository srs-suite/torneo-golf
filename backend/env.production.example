# ============================================
# CONFIGURACIÓN DE PRODUCCIÓN
# ============================================
# IMPORTANTE: NO subir este archivo con valores reales a Git
# Renombrar a .env en el servidor de producción

# ============================================
# BASE DE DATOS
# ============================================
DB_HOST=localhost
DB_USER=teetracker
DB_PASSWORD=TU_PASSWORD_SUPER_SEGURA_AQUI
DB_NAME=teetracker_pro
DB_PORT=3306

# ============================================
# SERVIDOR
# ============================================
NODE_ENV=production
# En el VPS InMotion: Nginx proxy_pass → 127.0.0.1:8001 (debe coincidir con .env.prod)
PORT=8001

# ============================================
# SEGURIDAD
# ============================================
# Generar claves aleatorias fuertes (mínimo 64 caracteres)
# Puedes generarlas con: openssl rand -base64 64
JWT_SECRET=GENERA_UNA_CLAVE_ALEATORIA_AQUI_64_CARACTERES_MINIMO
SESSION_SECRET=GENERA_OTRA_CLAVE_ALEATORIA_AQUI_64_CARACTERES_MINIMO

# ============================================
# CORS (Dominios permitidos)
# ============================================
ALLOWED_ORIGINS=https://teetracker.com,https://www.teetracker.com

# ============================================
# LOGS
# ============================================
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# ============================================
# LÍMITES
# ============================================
MAX_REQUEST_SIZE=10mb
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

