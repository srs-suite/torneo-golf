# ==============================================
# TeeTracker Pro - Variables de Entorno
# ==============================================
# Copia este archivo como .env y configura los valores

# ==============================================
# BASE DE DATOS
# ==============================================
DB_HOST=localhost
DB_PORT=3306
DB_USER=tu_usuario_mysql
DB_PASSWORD=tu_password_mysql
DB_NAME=torneogolf

# ==============================================
# SERVIDOR
# ==============================================
PORT=8000
NODE_ENV=development

# ==============================================
# AUTENTICACIÓN JWT
# ==============================================
# IMPORTANTE: Cambia estos valores en producción
JWT_SECRET=tu_jwt_secreto_super_seguro_aqui
JWT_EXPIRES_IN=7d

# ==============================================
# CORS Y FRONTEND
# ==============================================
# URL del frontend para CORS
FRONTEND_URL=http://localhost:5173

# ==============================================
# ARCHIVOS Y UPLOADS
# ==============================================
# Directorio para archivos subidos
UPLOAD_PATH=uploads

# Tamaño máximo de archivo (en bytes)
# 2MB = 2097152 bytes
MAX_FILE_SIZE=2097152

# ==============================================
# RATE LIMITING
# ==============================================
# Ventana de tiempo en milisegundos (15 minutos = 900000)
RATE_LIMIT_WINDOW_MS=900000

# Máximo número de requests por ventana
RATE_LIMIT_MAX_REQUESTS=100

# ==============================================
# TRANSPARENCIA FINANCIERA PÚBLICA
# ==============================================
# Contraseña compartida para que los socios vean las finanzas
# Esta contraseña se comparte entre todos los socios del club
PUBLIC_FINANCE_PASSWORD=socios2024

# ==============================================
# CONFIGURACIÓN DE PRODUCCIÓN
# ==============================================
# Para producción, usa estos valores:
#
# DB_HOST=vps123353.inmotionhosting.com
